{
  "name": "meutreino-frontend",
  "private": true,
  "version": "1.14.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @meutreino/web-pwa --",
    "build": "npm run build -w @meutreino/web-pwa --",
    "preview": "npm run preview -w @meutreino/web-pwa --",
    "lint": "npm run lint -w @meutreino/web-pwa --",
    "test": "node --test packages/core-domain/src/*.test.js",
    "test:integration": "npm run test:integration -w @meutreino/web-pwa --",
    "test:e2e": "npm run test:e2e -w @meutreino/web-pwa --",
    "test:all": "npm run test && npm run test:integration",
    "prepare": "husky",
    "release": "bash ./scripts/release-auto.sh",
    "lance:pub": "bash ./scripts/release-auto.sh",
    "release:minor": "bash ./scripts/release-auto.sh minor",
    "release:major": "bash ./scripts/release-auto.sh major",
    "release:dry-run": "standard-version --dry-run",
    "commit:auto": "bash ./scripts/commit-auto.sh"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7",
    "standard-version": "^9.5.0"
  }
}
